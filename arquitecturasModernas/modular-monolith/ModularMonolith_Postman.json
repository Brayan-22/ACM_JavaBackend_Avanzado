        {
          "name": "Crear Producto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Teclado Mecánico RGB\",\n  \"precio\": 120.00,\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/modular/producto",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "modular",
                "producto"
              ]
            }
          }
        },
        {
          "name": "Obtener Todos los Productos",
