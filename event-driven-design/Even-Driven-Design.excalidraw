    {
      "id": "Dk6wdq4xHPkHoDFv4jxP8",
      "type": "text",
      "x": 4690.739331951706,
      "y": -1306.9294746702417,
      "width": 703.7725255450831,
      "height": 155.33091044697161,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ax",
      "roundness": null,
      "seed": 1817370481,
      "version": 359,
      "versionNonce": 491340255,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777152230528,
      "link": null,
      "locked": false,
      "text": "Ventajas\n- Escalabilidad flexible\n- Mayor agilidad en desarrollo, facilitando enfoques agile\n- Resiliencia, si un servicio falla, no necesariamente se detiene toda la\naplicación\n- Orientados a la nube",
      "fontSize": 20.71078805959622,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ventajas\n- Escalabilidad flexible\n- Mayor agilidad en desarrollo, facilitando enfoques agile\n- Resiliencia, si un servicio falla, no necesariamente se detiene toda la\naplicación\n- Orientados a la nube",
      "autoResize": true,
      "lineHeight": 1.25
