    {
      "id": "x2fV7dJaSaA4CWRirIakh",
      "type": "text",
      "x": 3858.9906855977065,
      "y": -1305.3203545405377,
      "width": 712.2018946586822,
      "height": 181.2193955214669,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "au",
      "roundness": null,
      "seed": 1742651409,
      "version": 407,
      "versionNonce": 819649951,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777152230528,
      "link": null,
      "locked": false,
      "text": "Características\n- Despliegue independiente\n- Pequeños y autónomos\n- Organizados por capacidad de negocio\n- Poliglotas. es decir se pueden utilizar diferentes tecnologias o bases\nde datos para cada servicio independiente\n",
      "fontSize": 20.71078805959622,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Características\n- Despliegue independiente\n- Pequeños y autónomos\n- Organizados por capacidad de negocio\n- Poliglotas. es decir se pueden utilizar diferentes tecnologias o bases\nde datos para cada servicio independiente\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
