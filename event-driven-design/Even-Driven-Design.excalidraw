      "isDeleted": false,
      "boundElements": [],
      "updated": 1777154218178,
      "link": null,
      "locked": false,
      "text": "Consistencia eventual\n- Los sistemas no quedan sincronizados inmediatamente, pero \nconvergen con el tiempo\n- Ejemplo:\n    - Se crea una orden ahora, el inventario se actualiza unos \n    segundos después",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Consistencia eventual\n- Los sistemas no quedan sincronizados inmediatamente, pero \nconvergen con el tiempo\n- Ejemplo:\n    - Se crea una orden ahora, el inventario se actualiza unos \n    segundos después",
      "autoResize": true,
      "lineHeight": 1.25
    },
