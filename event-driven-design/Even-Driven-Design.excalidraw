    {
      "id": "DyvuS1uCObn4h4vff1R6I",
      "type": "text",
      "x": 2656.6311646981,
      "y": 1435.8513905899367,
      "width": 889.9556274414062,
      "height": 210,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
