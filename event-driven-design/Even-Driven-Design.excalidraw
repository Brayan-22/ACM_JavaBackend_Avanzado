    {
      "id": "PfzfJnAnowEXmBtq-9h7V",
      "type": "text",
      "x": 5595.615004899989,
      "y": 1620.0206539726541,
      "width": 826.92724609375,
      "height": 420,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0j",
