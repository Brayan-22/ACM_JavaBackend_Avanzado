    },
    {
      "id": "nbhDBUtxrgHOmOVL1_nvd",
      "type": "text",
      "x": 2940.506310387674,
      "y": 2301.4402936597808,
      "width": 687.2762451171875,
      "height": 270,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1m",
      "roundness": null,
      "seed": 1579049663,
      "version": 299,
      "versionNonce": 1665296177,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777155632443,
      "link": null,
      "locked": false,
      "text": "Aunque los eventos no resuelven este \nproblema de diseño de sistemas por si\nsolos, ayudan a diseñar el mejor \n\"trade-off\", ya que desacoplan, toleran \nparticionamiento y aceptan la \nconsistencia eventual",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Aunque los eventos no resuelven este \nproblema de diseño de sistemas por si\nsolos, ayudan a diseñar el mejor \n\"trade-off\", ya que desacoplan, toleran \nparticionamiento y aceptan la \nconsistencia eventual",
      "autoResize": true,
      "lineHeight": 1.25
    },
