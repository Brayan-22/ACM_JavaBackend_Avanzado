    {
      "id": "bJhpzqeeafhzNtsjs478T",
      "type": "text",
      "x": 5585.05391250604,
      "y": 633.8076347622684,
      "width": 873.4356079101562,
      "height": 420,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
